s-serif;color:rgb(0,0,0)'><br></font></div>  <table cellpadding=\\\"0\\\" cellspacing=\\\"0\\\" style=\\\"border-spacing:0px;border-collapse:collapse;width:480px;font-size:9pt;font-family:Arial,sans-serif;line-height:14px;color:rgb(68,68,68)\\\"><tbody style=\\\"font-family:Arial,sans-serif\\\">  <tr style=\\\"font-family:Arial,sans-serif\\\"><td colspan=\\\"2\\\" style=\\\"padding:0px 0px 5px;width:480px;font-family:Arial,sans-serif;color:rgb(60,60,59)\\\"><span style=\\\"font-size:11pt;font-weight:bold;font-family:Arial,sans-serif;color:rgb(0,0,0)\\\"><font style=\\\"font-family:Arial,sans-serif;color:rgb(0,0,0)\\\">Vann Laniakea</font></span></td></tr>  <tr style=\\\"font-family:Arial,sans-serif\\\"><td colspan=\\\"2\\\" style=\\\"padding:0px 0px 5px;width:480px;font-family:Arial,sans-serif;color:rgb(23,147,210)\\\"><span style=\\\"font-size:11pt;font-family:Arial,sans-serif;color:rgb(255,137,5)\\\"><font style=\\\"font-family:Arial,sans-serif;color:rgb(255,137,5)\\\">Founder &amp; CEO</font></span></td></tr>  <tr style=\\\"font-family:Arial,sans-serif\\\"><td colspan=\\\"2\\\" style=\\\"padding:0px 0px 2px;width:480px;border-top-width:1px;border-top-style:dotted;font-family:Arial,sans-serif;border-top-color:rgb(97,97,97)\\\"><br></td></tr>  <tr style=\\\"font-family:Arial,sans-serif\\\">  <td valign=\\\"middle\\\" style=\\\"padding:0px;width:120px;vertical-align:middle;font-family:Arial,sans-serif\\\">  <span style=\\\"font-family:Arial,Helvetica,sans-serif;font-size:small;text-align:center;color:rgb(32,33,36)\\\"> <img width=\\\"96\\\" height=\\\"96\\\" src=\\\"https://ci3.googleusercontent.com/mail-sig/AIorK4w_66CsntONATSSzeW2P0scNZLLvpdmW5wc9fv9UWlNwrCecVoYA18fNkHvDJ9b86GbARxid2QJ0JMu\\\" style=\\\"font-family: Arial, Helvetica, sans-serif\\\"></span><font style=\\\"font-family:Arial,sans-serif;color:rgb(68,68,68)\\\"><br></font>  </td>  <td valign=\\\"middle\\\" style=\\\"padding:0px;width:360px;vertical-align:middle;font-family:Arial,sans-serif;color:rgb(19,19,19)\\\"><table cellpadding=\\\"0\\\" cellspacing=\\\"0\\\" style=\\\"border-spacing:0px;border-collapse:collapse;font-family:Arial,sans-serif;background-color:transparent\\\"><tbody style=\\\"font-family:Arial,sans-serif\\\">  <tr style=\\\"font-family:Arial,sans-serif\\\"></tr>  <tr style=\\\"font-family:Arial,sans-serif\\\"></tr>  <tr style=\\\"font-family:Arial,sans-serif\\\"><td style=\\\"padding:1px;font-family:Arial,sans-serif\\\"><font style=\\\"font-family:Arial,sans-serif;color:rgb(19,19,19)\\\"><span style=\\\"font-size:9pt;font-family:Arial,sans-serif\\\"><br><a href=\\\"https://www.arlox.io/book-call\\\" rel=\\\"noreferrer\\\" target=\\\"_blank\\\" style=\\\"font-family:Arial,sans-serif\\\">Speak to an ad Expert</a><br><a href=\\\"mailto:support@arlox.io\\\" rel=\\\"noreferrer\\\" target=\\\"_blank\\\" style=\\\"font-family:Arial,sans-serif\\\">support@arlox.io</a></span><span style=\\\"font-family:Arial,sans-serif\\\"> - </span><a href=\\\"http://www.arlox.io/\\\" style=\\\"font-size:9pt;font-family:Arial,sans-serif\\\" rel=\\\"noreferrer\\\" target=\\\"_blank\\\"><span style=\\\"font-size:9pt;font-family:Arial,sans-serif\\\">www.arlox.io</span></a></font></td></tr>  <tr style=\\\"font-family:Arial,sans-serif\\\"><td style=\\\"padding:1px;font-family:Arial,sans-serif\\\"><span style=\\\"font-size:9pt;font-family:Arial,sans-serif;color:rgb(97,97,97)\\\"><font style=\\\"font-family:Arial,sans-serif;color:rgb(97,97,97)\\\">3533 Tiger Tower 1, Dubai Marina, Dubai, UAE <br><br></font></span></td></tr>  <tr style=\\\"font-family:Arial,sans-serif\\\"><td style=\\\"padding:2px 0px 0px 1px;font-family:Arial,sans-serif\\\"><span style=\\\"display:inline-block;height:23px;font-family:Arial,sans-serif\\\"><font style=\\\"font-family:Arial,sans-serif;color:rgb(19,19,19)\\\"><span style=\\\"font-family:Arial,sans-serif\\\"><a href=\\\"https://www.facebook.com/arlox.io\\\" style=\\\"font-family:Arial,sans-serif;background-color:transparent;color:rgb(51,122,183)\\\" rel=\\\"noreferrer\\\" target=\\\"_blank\\\"><img alt=\\\"Facebook icon\\\" width=\\\"23\\\" height=\\\"23\\\" src=\\\"https://codetwocdn.azureedge.net/images/mail-signatures/generator-dm/compact-logo/fb.png\\\" style=\\\"border: 0px; vertical-align: middle; height: 23px; width: 23px; font-family: Arial, sans-serif\\\"></a>  </span><span style=\\\"font-family:Arial,sans-serif\\\"><a href=\\\"https://www.linkedin.com/in/van-gawker-742907a3/\\\" style=\\\"font-family:Arial,sans-serif;background-color:transparent;color:rgb(51,122,183)\\\" rel=\\\"noreferrer\\\" target=\\\"_blank\\\"><img alt=\\\"LinkedIn icon\\\" width=\\\"23\\\" height=\\\"23\\\" src=\\\"https://codetwocdn.azureedge.net/images/mail-signatures/generator-dm/compact-logo/ln.png\\\" style=\\\"border: 0px; vertical-align: middle; height: 23px; width: 23px; font-family: Arial, sans-serif\\\"></a>  </span></font></span></td></tr>  </tbody></table></td>  </tr>  <tr style=\\\"font-family:Arial,sans-serif\\\"><td colspan=\\\"2\\\" style=\\\"padding:2px 0px 0px;width:480px;border-bottom-width:1px;border-bottom-style:dotted;font-family:Arial,sans-serif;border-bottom-color:rgb(97,97,97)\\\"> </td></tr>  </tbody></table>  <div dir=\\\"ltr\\\" style='font-family:-apple-system,BlinkMacSystemFont,\\\"Segoe UI\\\",Roboto,\\\"Helvetica Neue\\\",Arial,sans-serif'></div>  </div></div>  </blockquote></div>                            </blockquote>                          </div>  </div>                         </div> </blockquote> </blockquote></div>\\n                          </blockquote>\\n                        </div>\\n<br>\\n\\n\\n\\n\\n\\n\\n</div></blockquote>\\n</blockquote></div>\",\"body_text\":\"Dear Team Razorpay,\\r\\n\\r\\nI am writing to follow up on my previous request regarding the transaction\\r\\nlimit increase for my account (Ticket ID: #18045214).\\r\\n\\r\\nWe have partnered with Razorpay for the last five years without issue, and\\r\\nI have always valued the professional and proactive support your team\\r\\nprovided. However, my recent experience has been disappointing. Receiving\\r\\nautomated replies and generic directives to read the website—rather than\\r\\naddressing the technical errors I have reported—is hindering our operations.\\r\\n\\r\\nPlease be advised that if the limit for both national and international\\r\\ntransactions is not increased to 10 lakhs immediately, we will be forced to\\r\\nexplore alternative payment providers. Given our transaction volume, this\\r\\nwould result in a loss of over ₹30,000 in fees per transaction for your\\r\\nplatform.\\r\\n\\r\\nI urge you to resolve the technical issues I am facing on the dashboard and\\r\\nproceed with the requested limit increase.\\r\\n\\r\\nRegards,\\r\\n\\r\\nVann Laniakea\\r\\n\\r\\n\\r\\nVann Laniakea\\r\\nFounder & CEO\\r\\n\\r\\n\\r\\n\\r\\nSpeak to an ad Expert <https://www.arlox.io/book-call>\\r\\nsupport@arlox.io - www.arlox.io\\r\\n3533 Tiger Tower 1, Dubai Marina, Dubai, UAE\\r\\n\\r\\n[image: Facebook icon] <https://www.facebook.com/arlox.io>  [image:\\r\\nLinkedIn icon] <https://www.linkedin.com/in/van-gawker-742907a3/>\\r\\n\\r\\n\\r\\n\\r\\nOn Thu, Feb 19, 2026 at 5:47 PM Razorpay support \",\"structured_body\":null,\"id\":83226238443,\"incoming\":true,\"private\":false,\"user_id\":82072804228,\"support_email\":\"van@arlox.io\",\"source\":0,\"category\":1,\"to_emails\":[\"\\\"Razorpay support\\\" <rzr06py08emsp@razorpay.com>\"],\"from_email\":\"van@arlox.io\",\"cc_emails\":[],\"bcc_emails\":[],\"email_failure_count\":null,\"outgoing_failures\":null,\"thread_id\":null,\"thread_message_id\":null,\"created_at\":\"2026-02-19T12:23:10Z\",\"updated_at\":\"2026-02-19T12:23:10Z\",\"last_edited_at\":null,\"last_edited_user_id\":null,\"attachments\":[],\"automation_id\":null,\"automation_type_id\":null,\"automation_channel_type\":null,\"auto_response\":false,\"ticket_id\":18125250,\"threading_type\":null,\"delivery_details\":{\"failed_emails\":[],\"pending_emails\":[]},\"deleted\":false,\"cloud_files\":[],\"has_quoted_text\":false}}]},{\"id\":17715034596733,\"performer\":{\"type\":\"user\",\"user_id\":82215018082},\"highlight\":40,\"ticket_id\":18125250,\"performed_at\":\"2026-02-19T12:17:39Z\",\"actions\":[{\"type\":\"property_update\",\"content\":{\"custom_fields\":{\"cf_yogi_resolution\":\"not_eligible_for_auto_closure\"}}}]},{\"id\":17715034554987,\"performer\":{\"type\":\"system\",\"system\":{\"id\":82000695322,\"type\":\"observer\",\"name\":\"Function update - CS tickets\",\"exists\":true}},\"highlight\":40,\"ticket_id\":18125250,\"performed_at\":\"2026-02-19T12:17:35Z\",\"actions\":[{\"type\":\"property_update\",\"content\":{\"custom_fields\":{\"cf_function\":\"CS\"}}}]},{\"id\":17715034529115,\"performer\":{\"type\":\"user\",\"user_id\":82007884864},\"highlight\":40,\"ticket_id\":18125250,\"performed_at\":\"2026-02-19T12:17:32Z\",\"actions\":[{\"type\":\"property_update\",\"content\":{\"custom_fields\":{\"cf_ai_sentiment_score\":\"*\",\"cf_escalation_indicator\":\"*\"}}}]},{\"id\":17715034528398,\"performer\":{\"type\":\"user\",\"user_id\":82207208810},\"highlight\":40,\"ticket_id\":18125250,\"performed_at\":\"2026-02-19T12:17:32Z\",\"actions\":[{\"type\":\"property_update\",\"content\":{\"custom_fields\":{\"cf_counter_group_transfer\":\"1\"}}}]},{\"id\":17715034519952,\"performer\":{\"type\":\"system\",\"system\":{\"id\":0,\"type\":\"round_robin\",\"name\":\"\",\"exists\":true}},\"highlight\":37,\"ticket_id\":18125250,\"performed_at\":\"2026-02-19T12:17:31Z\",\"actions\":[{\"type\":\"round_robin\",\"content\":{\"responder_id\":82219712071}}]},{\"id\":17715034515314,\"performer\":{\"type\":\"system\",\"system\":{\"id\":82000702262,\"type\":\"observer\",\"name\":\"Non Existence of Contact number\",\"exists\":true}},\"highlight\":40,\"ticket_id\":18125250,\"performed_at\":\"2026-02-19T12:17:31Z\",\"actions\":[{\"type\":\"property_update\",\"content\":{\"custom_fields\":{\"cf_contact_number_existing\":\"No\"}}}]},{\"id\":17715034514842,\"pe